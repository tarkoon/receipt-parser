# Receipt Parser — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── DeepSeek API (required) ──────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── OpenRouter API (optional, fallback if DeepSeek key is not set) ───
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Google Cloud Platform ────────────────────────────────────────────
# Your GCP project ID (required for Cloud Vision OCR)
# Enable the Cloud Vision API at: https://console.cloud.google.com/apis/library/vision.googleapis.com
# Authenticate with: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
