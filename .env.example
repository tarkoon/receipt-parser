# Receipt Parser — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── DeepSeek API (required) ──────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── OpenRouter API (optional, explicit routed/triage models only) ────
# Get your key at: https://openrouter.ai/keys
# The default DeepSeek model uses DEEPSEEK_API_KEY directly, not OpenRouter.
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional validator-gated model triage. Leave blank/omitted for normal runs.
# Example:
# RECEIPT_TRIAGE_MODELS=openrouter/anthropic/claude-sonnet-4.6,openrouter/anthropic/claude-opus-4.7
# RECEIPT_TRIAGE_MAX_TOKENS=2048

# ── Google Cloud Platform ────────────────────────────────────────────
# Your GCP project ID (required for Cloud Vision OCR)
# Enable the Cloud Vision API at: https://console.cloud.google.com/apis/library/vision.googleapis.com
# Authenticate with: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
